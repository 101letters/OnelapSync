# ─── OneLap / 顽鹿 登录凭证 ──────────
ONELAP_USERNAME=your_phone_or_email
ONELAP_PASSWORD=your_password
ONELAP_SIGN_KEY=your_onelap_sign_key
ONELAP_LOGIN_URL=https://www.onelap.cn/api/login
ONELAP_OTM_BASE=https://otm.onelap.cn

# ─── Strava API ──────────────────────
STRAVA_API_BASE=https://www.strava.com/api/v3
STRAVA_OAUTH_URL=https://www.strava.com/oauth/token
STRAVA_ACCESS_TOKEN=your_strava_access_token
STRAVA_REFRESH_TOKEN=your_strava_refresh_token
STRAVA_CLIENT_ID=your_strava_api_client_id
STRAVA_CLIENT_SECRET=your_strava_api_client_secret

# ─── 通知（可选）────────────────────
BARK_URL=https://api.day.app/your_bark_device_key

# ─── 数据分析（可选）────────────────
# ANALYSIS_MAX_HR=194

# ─── 彩云天气（可选）─────────────────
CAIYUN_API_BASE=https://api.caiyunapp.com/v2.5
CAIYUN_TOKEN=your_caiyun_token
CAIYUN_LOCATION=经度,纬度

# ─── 和风天气（可选）─────────────────
QWEATHER_HOST=your_qweather_host
QWEATHER_KEY=your_qweather_key
QWEATHER_LOCATION=经度,纬度

# ─── 同步中转服务（可选）────────────
CCROUTE_BASE_URL=https://ccroute.cn

# ─── QwenPaw 渠道推送（可选）─────────
# QWENPAW_TARGET_USER=your_user_id
# QWENPAW_TARGET_SESSION=telegram:your_chat_id
# QWENPAW_AGENT_ID=default
